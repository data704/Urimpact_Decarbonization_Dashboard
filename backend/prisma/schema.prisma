// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
// Administrator = full org control; Data Contributor = upload only;
// Analyst = reports/analytics only; Viewer = read-only; SUPER_ADMIN = platform
enum UserRole {
  SUPER_ADMIN
  ADMINISTRATOR
  DATA_CONTRIBUTOR
  ANALYST
  VIEWER
}

enum DocumentType {
  UTILITY_BILL
  FUEL_RECEIPT
  INVOICE
  OTHER
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

enum EmissionScope {
  SCOPE_1
  SCOPE_2
  SCOPE_3
}

enum EmissionCategory {
  ELECTRICITY
  NATURAL_GAS
  FUEL_COMBUSTION
  TRANSPORTATION
  WASTE
  WATER
  REFRIGERANTS
  BUSINESS_TRAVEL
  EMPLOYEE_COMMUTING
  PURCHASED_GOODS
  OTHER
}

// Organization (tenant) — signup creates an org; all members share one dashboard
model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Tab visibility + commercial tier (e.g. FREE, STANDARD, ENTERPRISE)
  subscriptionPlan String @default("STANDARD")

  /// When set, company onboarding wizard is considered complete for all org users
  onboardingCompletedAt DateTime?

  // Company onboarding (GHG / ISIC-aligned profile)
  legalName                    String?
  commercialRegistrationNumber String?
  registrationDocumentPath     String?
  headquarterAddress           String?
  isGroupCompany               Boolean  @default(false)
  groupCompanyName             String?
  sectorIsicCode               String?
  subSectorIsicCode            String?
  revenueAmount                Decimal? @db.Decimal(18, 2)
  revenueCurrency              String?
  employeeCount                Int?

  pocFullName      String?
  pocDesignation     String?
  pocDepartment      String?
  pocEmail           String?
  pocPhone           String?
  pocCountryCode     String?

  onboardingDraft Json?

  /// Facility registry captured during company onboarding (GHG boundary mapping)
  onboardingFacilities Json?

  /// Wizard draft for Scope 1–3 boundary questions (merged JSON, e.g. { scope1: {...} })
  scopeOnboardingDraft Json?
  /// Submitted Scope 1 inventory snapshot (vehicles, stationary, refrigerants)
  scope1Inventory            Json?
  scope1OnboardingCompletedAt DateTime?

  /// Submitted Scope 2 baseline (facilities, purchased electricity/steam/heat/cooling)
  scope2Inventory            Json?
  scope2OnboardingCompletedAt DateTime?

  users     User[]
  emissions Emission[]
  documents Document[]

  @@map("organizations")
}

// User Model
model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  firstName      String
  lastName       String
  company        String?
  organizationId String?
  role           UserRole  @default(ADMINISTRATOR)
  isActive       Boolean   @default(true)
  emailVerified  Boolean   @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  /// First login / admin-provisioned accounts must change password before full access
  passwordMustChange Boolean @default(false)

  /// TOTP secret (base32), stored encrypted-at-rest in production via env; optional 2FA
  totpSecret     String?
  totpEnabled    Boolean   @default(false)

  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  documents     Document[]
  emissions     Emission[]
  auditLogs     AuditLog[]
  clientConfigs ClientConfig[]
  loginChallenges LoginChallenge[]

  @@index([email])
  @@index([company])
  @@index([organizationId])
  @@map("users")
}

/// Email OTP step after password verification (JWT issued only after OTP + optional TOTP)
model LoginChallenge {
  id         String   @id @default(uuid())
  email      String
  otpHash    String
  expiresAt  DateTime
  rememberMe Boolean  @default(false)
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([userId])
  @@map("login_challenges")
}

// Client Inputs & Constraints (decarbonisation pathway config)
model ClientConfig {
  id                    String   @id @default(uuid())
  userId                String
  targetYear            Int
  ambitionLevel         String
  capexOpexPreference   String?
  supportingDocuments   Json?    // array of file names/paths
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("client_configs")
}

// Document Model
model Document {
  id             String         @id @default(uuid())
  userId         String
  organizationId String?
  fileName      String
  fileType      String
  fileSize      Int
  filePath      String
  s3Key         String?
  documentType  DocumentType   @default(OTHER)
  status        DocumentStatus @default(UPLOADED)
  ocrData       Json?
  extractedData Json?
  errorMessage  String?
  processedAt   DateTime?
  uploadedAt    DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  emissions    Emission[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([documentType])
  @@index([uploadedAt])
  @@map("documents")
}

// Emission Model
model Emission {
  id                 String           @id @default(uuid())
  userId             String
  organizationId     String?
  documentId         String?
  siteId             String?
  siteName           String?
  scope              EmissionScope
  category           EmissionCategory
  activityType       String
  activityAmount     Float
  activityUnit       String
  region             String           @default("AE")
  co2e               Float            // Total CO2 equivalent in kg
  co2                Float?           // CO2 in kg
  ch4                Float?           // Methane in kg
  n2o                Float?           // Nitrous oxide in kg
  emissionFactor     Float
  emissionFactorUnit String
  dataSource         String?          // e.g., "Climatiq", "EPA", "DEFRA"
  dataYear           Int?
  calculatedAt       DateTime         @default(now())
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  document     Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([documentId])
  @@index([scope])
  @@index([category])
  @@index([calculatedAt])
  @@index([region])
  @@map("emissions")
}

// Emission Factors Cache Model
model EmissionFactor {
  id           String   @id @default(uuid())
  activityId   String   @unique
  category     String
  subcategory  String?
  region       String
  fuelType     String?
  unit         String
  co2Factor    Float
  ch4Factor    Float?
  n2oFactor    Float?
  co2eFactor   Float
  source       String   // EPA, DEFRA, IEA, IPCC, Climatiq
  year         Int
  qualityTier  Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([activityId])
  @@index([category])
  @@index([region])
  @@map("emission_factors")
}

// Audit Log Model
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([timestamp])
  @@map("audit_logs")
}

// Refresh Token Model (for JWT refresh)
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

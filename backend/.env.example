# Server
NODE_ENV=development
PORT=5000

# Database (e.g. Docker Postgres from docker-compose)
DATABASE_URL=postgresql://urimpact:urimpact_password@localhost:5433/urimpact

# JWT (change in production)
JWT_SECRET=your-secret-key-change-in-production

# Anthropic (Claude) API - required for receipt extraction & report insights
ANTHROPIC_API_KEY=
# Optional:
# ANTHROPIC_API_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_MAX_TOKENS=4096

# Climatiq API - for emission calculations when receipts are submitted (optional; fallback factors used if missing)
# Get your key: https://www.climatiq.io/ (sign up → API key). Place it here:
CLIMATIQ_API_KEY=
# Optional: override API base URL (default: https://api.climatiq.io)
# CLIMATIQ_API_URL=https://api.climatiq.io

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Auth — login OTP (no email provider / testing)
# OTP is returned in the login API as `debugOtp` and shown on the sign-in screen whenever SMTP is NOT fully
# configured (SMTP_HOST + MAIL_FROM or SMTP_USER). Works in production for testing without a mail service.
# When you add SMTP later, set EXPOSE_LOGIN_OTP=false to stop returning the code in the API (email only).
# EXPOSE_LOGIN_OTP=false
# EXPOSE_LOGIN_OTP=true   # optional: always return code in API even if SMTP is set (debug only)
#
# Optional SMTP (when ready for real email)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="URIMPACT <noreply@example.com>"
#
# SKIP_LOGIN_OTP=false   # local dev: require OTP step (dev default otherwise skips OTP)
# SKIP_LOGIN_OTP=true   # production: optional password-only login (no OTP step)
# CORPORATE_EMAIL_DOMAINS=yourcompany.com

# Redis (optional)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# File upload (include xlsx,xls for Excel receipt uploads)
# MAX_FILE_SIZE=10485760
# ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,xlsx,xls

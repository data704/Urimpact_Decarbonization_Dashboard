# Server
NODE_ENV=development
PORT=5000

# Database (e.g. Docker Postgres from docker-compose)
DATABASE_URL=postgresql://urimpact:urimpact_password@localhost:5433/urimpact

# JWT (change in production)
JWT_SECRET=your-secret-key-change-in-production

# Anthropic (Claude) API - required for receipt extraction & report insights
ANTHROPIC_API_KEY=
# Optional:
# ANTHROPIC_API_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_MAX_TOKENS=4096

# Climatiq API - for emission calculations when receipts are submitted (optional; fallback factors used if missing)
# Get your key: https://www.climatiq.io/ (sign up → API key). Place it here:
CLIMATIQ_API_KEY=
# Optional: override API base URL (default: https://api.climatiq.io)
# CLIMATIQ_API_URL=https://api.climatiq.io

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Redis (optional)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# File upload (include xlsx,xls for Excel receipt uploads)
# MAX_FILE_SIZE=10485760
# ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,xlsx,xls
